  - type: article
    title: >-
      Perceptually uniform color space for image signals including high
      dynamic range and wide gamut
    authors:
      - family-names: Safdar
        given-names: Muhammad
      - family-names: Cui
        given-names: Guihua
      - family-names: Kim
        given-names: Youn Jin
      - family-names: Luo
        given-names: M. Ronnier
    journal: "Optics Express"
